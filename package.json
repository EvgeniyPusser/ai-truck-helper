{
  "name": "holymove-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "server/index.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "dev": "tsx watch server/index.js",
    "dev:trace": "node --trace-warnings --loader tsx server/index.js",
    "build": "npm install --production=false",
    "start": "tsx server/index.js",
    "start:dev": "tsx server/index.js",
    "front:dev": "npm --prefix frontend run dev"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.24.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "framer-motion": "^12.23.12",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "tsx": "^4.20.4"
  }
}
